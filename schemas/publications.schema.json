{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "publications.schema.json",
    "title": "Publications",
    "type": "object",
    "required": ["items"],
    "additionalProperties": false,
    "properties": {
        "items": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["title", "authors", "venue", "year"],
                "additionalProperties": false,
                "properties": {
                    "title": { "type": "string", "minLength": 1 },
                    "authors": {
                        "type": "array",
                        "items": { "type": "string" },
                        "minItems": 1
                    },
                    "venue": { "type": "string" },
                    "year": {
                        "type": "integer",
                        "minimum": 1900,
                        "maximum": 2100
                    },
                    "type": {
                        "type": "string",
                        "enum": [
                            "conference",
                            "journal",
                            "workshop",
                            "preprint",
                            "thesis",
                            "book",
                            "chapter",
                            "other"
                        ]
                    },
                    "highlight": { "type": "boolean" },
                    "include": { "type": "boolean" },
                    "abstract": { "type": "string" },
                    "key": { "type": "string" },
                    "doi": { "type": "string" },
                    "arxiv": { "type": "string" },
                    "source": {
                        "type": "string",
                        "enum": ["manual", "inspire"]
                    },
                    "claimed": { "type": "boolean" },
                    "author_count": { "type": "integer", "minimum": 1 },
                    "collaboration": { "type": "boolean" },
                    "links": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["label", "url"],
                            "additionalProperties": false,
                            "properties": {
                                "label": { "type": "string" },
                                "url": { "type": "string" }
                            }
                        }
                    }
                }
            }
        }
    }
}
