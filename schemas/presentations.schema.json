{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "presentations.schema.json",
    "title": "Presentations",
    "type": "object",
    "required": ["items"],
    "additionalProperties": false,
    "properties": {
        "items": {
            "type": ["array", "null"],
            "items": {
                "type": "object",
                "required": ["kind", "title", "event", "date"],
                "additionalProperties": false,
                "properties": {
                    "kind": { "type": "string", "enum": ["talk", "workshop"] },
                    "title": { "type": "string", "minLength": 1 },
                    "event": { "type": "string" },
                    "location": { "type": "string" },
                    "date": { "type": "string", "format": "date" },
                    "url": { "type": "string" }
                }
            }
        }
    }
}
