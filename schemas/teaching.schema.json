{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "teaching.schema.json",
    "title": "Teaching",
    "type": "object",
    "required": ["items"],
    "additionalProperties": false,
    "properties": {
        "items": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["course", "role", "institution", "term"],
                "additionalProperties": false,
                "properties": {
                    "course": { "type": "string", "minLength": 1 },
                    "role": { "type": "string" },
                    "institution": { "type": "string" },
                    "term": { "type": "string" },
                    "url": { "type": "string" }
                }
            }
        }
    }
}
